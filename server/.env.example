# TuneX backend environment variables

# MongoDB connection string
MONGODB_URI=your-mongodb-connection-string

# TuneX frontend origin and redirect URI
FRONTEND_URL=https://tune-x-henna.vercel.app
GOOGLE_REDIRECT_URI=https://tune-x-henna.vercel.app/google-callback.html

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini API key for AI tuning
GEMINI_API_KEY=your-gemini-api-key